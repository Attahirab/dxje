<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Expense Tracker</title>
<style>
  body { font-family: Arial; background: #0a0a0a; color: #0f0; text-align: center; padding: 40px; }
  input, button { padding: 10px; margin: 5px; }
  table { margin: 30px auto; border-collapse: collapse; width: 80%; }
  th, td { border: 1px solid #0f0; padding: 10px; }
</style>
</head>
<body>
<h1>💰 Expense Tracker</h1>
<input id="desc" placeholder="Description">
<input id="amount" type="number" placeholder="Amount">
<button onclick="addExpense()">Add</button>
<table id="table"><thead><tr><th>Date</th><th>Description</th><th>Amount</th></tr></thead><tbody></tbody></table>
<div id="total">Total: $0</div>

<script>
let expenses = [];
function addExpense() {
  const desc = document.getElementById('desc').value;
  const amt = parseFloat(document.getElementById('amount').value);
  if (!desc || !amt) return;
  expenses.push({date: new Date().toLocaleDateString(), desc, amt});
  render();
  document.getElementById('desc').value = '';
  document.getElementById('amount').value = '';
}
function render() {
  const tbody = document.querySelector('#table tbody');
  tbody.innerHTML = expenses.map(e => `<tr><td>${e.date}</td><td>${e.desc}</td><td>$${e.amt}</td></tr>`).join('');
  const total = expenses.reduce((sum, e) => sum + e.amt, 0);
  document.getElementById('total').textContent = `Total: $${total}`;
}
</script>
</body>
</html>
